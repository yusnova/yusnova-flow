# STLC orchestrator (optional — falls back to heuristics when unset)
# STLC_LLM_API_KEY=
# STLC_LLM_BASE_URL=https://api.openai.com/v1
# STLC_LLM_MODEL=gpt-4o-mini
# STLC_EMBEDDING_MODEL=text-embedding-3-small
# STLC_USE_LLM=true

# STLC tmp retention (auto-prune runs before each stlc:orchestrator start)
# STLC_TMP_KEEP_RUNS=15
# STLC_TMP_MAX_AGE_DAYS=14

# Application-under-test source root (FE) for API + selector scanning
# STLC_APP_ROOT=../frontend

# OpenAPI / Swagger spec for `npm run swagger:api` (booking demo default)
SWAGGER_PATH=../backend/openapi.json

# ---------------------------------------------------------------------------
# Demo environment URLs — override for YOUR app. Defaults in config.ts stay
# generic (*.example.com). The values below target the local booking demo
# under ../frontend + ../backend for framework testing only.
# ---------------------------------------------------------------------------
DEMO_BASE_URL=http://localhost:3000
DEMO_LOGIN_URL=http://localhost:3000
DEMO_SIGNUP_URL=http://localhost:3000
DEMO_API_BASE_URL=http://localhost:3000/api

# Set true when the demo app has no login (e.g. local booking). Leave unset /
# false for apps that require UI + API auth setup.
DEMO_SKIP_AUTH=true

# DEV_BASE_URL=https://dev.example.com
# STAGING_BASE_URL=https://staging.example.com

REGULAR_USER_USERNAME=demo_user
REGULAR_USER_PASSWORD=change_me
ADMIN_USER_USERNAME=admin_user
ADMIN_USER_PASSWORD=change_me

API_REGULAR_USER_USERNAME=api_user
API_REGULAR_USER_PASSWORD=change_me
