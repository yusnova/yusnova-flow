# STLC orchestrator (optional — falls back to heuristics when unset)
# STLC_LLM_API_KEY=
# STLC_LLM_BASE_URL=https://api.openai.com/v1
# STLC_LLM_MODEL=gpt-4o-mini
# STLC_USE_LLM=true

# STLC tmp retention (auto-prune runs before each stlc:orchestrator start)
# STLC_TMP_KEEP_RUNS=15
# STLC_TMP_MAX_AGE_DAYS=14

REGULAR_USER_USERNAME=standard_user
REGULAR_USER_PASSWORD=secret_sauce
ADMIN_USER_USERNAME=locked_out_user
ADMIN_USER_PASSWORD=secret_sauce

# DummyJSON credentials for demo API tests (UI still uses REGULAR_USER_* on SauceDemo)
API_REGULAR_USER_USERNAME=emilys
API_REGULAR_USER_PASSWORD=emilyspass

# Optional overrides for cloud envs (ENV=aws-dev | aws-staging | gcp-dev)
# AWS_DEV_BASE_URL=
# AWS_DEV_LOGIN_URL=
# AWS_DEV_SIGNUP_URL=
# AWS_DEV_API_BASE_URL=
